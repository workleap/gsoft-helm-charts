{
  "version": "0",
  "id": "foobar",
  "workloads": {
    "demo-api": {
      "kind": "api",
      "image": {
        "registry": "myregistry.azurecr.io",
        "repository": "workleap-demo-api",
        "tag": "1.0.97"
      },
      "replicas": 3,
      "ingress": {
        "fqdn": "api.idp.workleap-dev.com",
        "pathPrefix": "/leap.shop",
        "annotations": {
          "nginx.ingress.kubernetes.io/proxy-body-size": "10m"
        }
      },
      "resources": {
        "requests": {
          "cpu": "100m",
          "memory": "256Mi"
        },
        "limits": {
          "memory": "512Mi"
        }
      },
      "probes": {
        "readiness": {
          "httpGet": {
            "path": "/health/ready",
            "port": "http"
          },
          "initialDelaySeconds": 5,
          "periodSeconds": 10
        },
        "liveness": {
          "httpGet": {
            "path": "/health/live",
            "port": "http"
          },
          "initialDelaySeconds": 10,
          "periodSeconds": 15
        }
      },
      "envVars": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "LOG_LEVEL": "Information"
      },
      "autoscaling": {
        "horizontal": {
          "enabled": true,
          "minReplicas": 2,
          "maxReplicas": 10
        }
      },
      "labels": {
        "team": "platform"
      },
      "annotations": {
        "app.workleap.com/owner": "platform-team"
      }
    },
    "workleap-sample-worker": {
      "kind": "worker",
      "image": {
        "registry": "myregistry.azurecr.io",
        "repository": "workleap-demo-api",
        "tag": "1.0.97"
      },
      "replicas": 2,
      "resources": {
        "requests": {
          "cpu": "50m",
          "memory": "128Mi"
        },
        "limits": {
          "memory": "256Mi"
        }
      },
      "envVars": {
        "WORKER_MODE": "background"
      }
    }
  }
}
